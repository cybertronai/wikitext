# Lambda Cloud REST API key — cloud.lambda.ai → API keys.
LAMBDA_API_KEY=<your-lambda-api-key>

# Your GitHub username (lowercased internally for the GHCR image tag).
# submit.py pushes the built image to ghcr.io/<GHCR_USER>/wikitext-bench:...
# Auth must already be set up:
#   gh auth token | docker login ghcr.io -u <GHCR_USER> --password-stdin
GHCR_USER=<your-github-username>
