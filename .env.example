# Modal auth normally lives in ~/.modal.toml — set up once with:
#   pip install modal
#   modal token new
#
# This .env is only needed for CI / non-interactive setups where
# ~/.modal.toml isn't available. Set both halves; the Modal SDK reads
# them transparently.
MODAL_TOKEN_ID=<ak-...>
MODAL_TOKEN_SECRET=<as-...>
